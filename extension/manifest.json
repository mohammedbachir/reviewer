{
  "manifest_version": 3,
  "name": "Reviewer",
  "version": "0.2.0",
  "description": "Smart replies for Google Business reviews.",
  "permissions": ["storage", "identity"],
  "host_permissions": [
    "*://business.google.com/*",
    "*://*.supabase.co/*",
    "*://*.vercel.app/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Reviewer"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://business.google.com/*"
      ],
      "js": ["lib/i18n.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
